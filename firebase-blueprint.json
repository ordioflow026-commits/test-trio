{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information including phone number and contacts.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "contacts": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "phoneNumber", "displayName"]
    },
    "Call": {
      "title": "Call Session",
      "description": "A call session between users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["one-on-one", "group"] },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants", "type", "status"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message sent during a call.",
      "type": "object",
      "properties": {
        "callId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["callId", "senderId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles indexed by UID."
    },
    "/calls/{callId}": {
      "schema": "Call",
      "description": "Call sessions indexed by call ID."
    },
    "/calls/{callId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a call session."
    }
  }
}
