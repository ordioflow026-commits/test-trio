rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - phoneNumber: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - contacts: array (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: calls
    // Document ID: {callId}
    // Fields:
    //   - id: string (required)
    //   - participants: array (required)
    //   - type: string (required, 'one-on-one' | 'group')
    //   - status: string (required, 'active' | 'ended')
    //   - createdAt: timestamp (required)
    //
    // Collection: calls/{callId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - callId: string (required)
    //   - senderId: string (required)
    //   - text: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(participants) {
      return isAuthenticated() && request.auth.uid in participants;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'phoneNumber', 'displayName', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.phoneNumber is string && data.phoneNumber.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidCall(data) {
      return data.keys().hasAll(['id', 'participants', 'type', 'status', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.participants is list && data.participants.size() > 0 &&
             data.type in ['one-on-one', 'group'] &&
             data.status in ['active', 'ended'] &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['callId', 'senderId', 'text', 'timestamp']) &&
             data.callId is string && data.callId.size() > 0 &&
             data.senderId is string && data.senderId.size() > 0 &&
             data.text is string && data.text.size() > 0 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      // Users can read their own profile and profiles of their contacts.
      // For simplicity, we allow reading any profile if authenticated,
      // but only the owner can write.
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /calls/{callId} {
      // Only participants can read and write to a call.
      allow read: if isParticipant(resource.data.participants);
      allow create: if isAuthenticated() && isValidCall(request.resource.data) && isParticipant(request.resource.data.participants);
      allow update: if isParticipant(resource.data.participants) && isValidCall(request.resource.data);

      match /messages/{messageId} {
        // Only participants of the parent call can read and write messages.
        allow read: if isParticipant(get(/databases/$(database)/documents/calls/$(callId)).data.participants);
        allow create: if isParticipant(get(/databases/$(database)/documents/calls/$(callId)).data.participants) && isValidMessage(request.resource.data);
      }
    }
  }
}
